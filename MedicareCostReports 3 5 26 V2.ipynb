   "source": [
    "# Broad scan — find anything that looks like ICU days\n",
    "# ICU days for a typical hospital: 500–50,000 range\n",
    "# Looking for broad population (2,000+ hospitals)\n",
    "\n",
    "sub = nmrc[\n",
    "    nmrc[\"WKSHT_CD\"].str.startswith(\"S\") &\n",
    "    (nmrc[\"ITM_VAL_NUM\"] >= 100) &\n",
    "    (nmrc[\"ITM_VAL_NUM\"] <= 100_000)\n",
    "]\n",
    "\n",
    "grp = (\n",
    "    sub.groupby([\"WKSHT_CD\",\"LINE_NUM\",\"CLMN_NUM\"])\n",
    "    .agg(\n",
    "        hosp_count=(\"RPT_REC_NUM\",\"nunique\"),\n",
    "        median_val=(\"ITM_VAL_NUM\",\"median\"),\n",
    "        max_val=(\"ITM_VAL_NUM\",\"max\"),\n",
    "    )\n",
    "    .reset_index()\n",
    "    .query(\"hosp_count >= 2000\")\n",
    "    .sort_values(\"hosp_count\", ascending=False)\n",
    "    .head(30)\n",
    ")\n",
    "print(grp.to_string(index=False))"
   ]
  },
