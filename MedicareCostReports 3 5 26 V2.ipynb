   "source": [
    "\"\"\"\n",
    "CONTRACT LABOR & BUDGETED/LICENSED FTE SNIFFER — FY2011–2023\n",
    "============================================================\n",
    "Finds verified addresses for:\n",
    "  1. Contract / agency labor costs\n",
    "  2. Budgeted / licensed FTEs\n",
    "\n",
    "Strategy:\n",
    "  - Phase 1: FY2011 broad scan to find candidates\n",
    "  - Phase 2: Multi-year verification of winning addresses\n",
    "\n",
    "OUTPUT:\n",
    "  1. Console summary\n",
    "  2. contract_budgeted_mapping_matrix.csv\n",
    "============================================================\n",
    "\"\"\"\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from pathlib import Path\n",
    "import warnings\n",
    "\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "\n",
    "BASE_DIR   = Path(r\"/mnt/c/Users/lfult/OneDrive - bc.edu/Desktop/CMS Cost Reports\")\n",
    "OUTPUT_DIR = BASE_DIR / \"processed_panel\"\n",
    "OUTPUT_DIR.mkdir(exist_ok=True)\n",
    "YEARS = list(range(2011, 2025))\n",
    "\n",
    "# ============================================================\n",
    "# HELPERS\n",
    "# ============================================================\n",
    "def sniff_delimiter(filepath):\n",
    "    with open(filepath, \"r\", encoding=\"latin1\", errors=\"replace\") as f:\n",
    "        line = f.readline()\n",
    "    counts = {\",\": line.count(\",\"), \"\\t\": line.count(\"\\t\"), \"|\": line.count(\"|\")}\n",
    "    return max(counts, key=counts.get)\n",
    "\n",
    "def load_nmrc(filepath):\n",
    "    sep = sniff_delimiter(filepath)\n",
    "    df = pd.read_csv(\n",
    "        filepath, sep=sep, header=None,\n",
    "        names=[\"RPT_REC_NUM\",\"WKSHT_CD\",\"LINE_NUM\",\"CLMN_NUM\",\"ITM_VAL_NUM\"],\n",
    "        encoding=\"latin1\", low_memory=False, dtype=str,\n",
    "    )\n",
    "    df[\"RPT_REC_NUM\"] = df[\"RPT_REC_NUM\"].astype(str).str.strip()\n",
    "    df[\"WKSHT_CD\"]    = df[\"WKSHT_CD\"].astype(str).str.strip()\n",
    "    df[\"LINE_NUM\"]    = df[\"LINE_NUM\"].astype(str).str.strip().str.zfill(5)\n",
    "    df[\"CLMN_NUM\"]    = df[\"CLMN_NUM\"].astype(str).str.strip().str.zfill(5)\n",
    "    df[\"ITM_VAL_NUM\"] = pd.to_numeric(df[\"ITM_VAL_NUM\"], errors=\"coerce\")\n",
    "    return df\n",
    "\n",
    "def probe(nmrc, ws, line, col, min_val=1):\n",
    "    sub = nmrc[\n",
    "        (nmrc[\"WKSHT_CD\"] == ws) &\n",
    "        (nmrc[\"LINE_NUM\"]  == str(line).zfill(5)) &\n",
    "        (nmrc[\"CLMN_NUM\"]  == str(col).zfill(5)) &\n",
    "        (nmrc[\"ITM_VAL_NUM\"].abs() >= min_val)\n",
    "    ]\n",
    "    n   = sub[\"RPT_REC_NUM\"].nunique()\n",
    "    med = sub[\"ITM_VAL_NUM\"].median() if n > 0 else None\n",
    "    mx  = sub[\"ITM_VAL_NUM\"].max()    if n > 0 else None\n",
    "    return n, med, mx\n",
    "\n",
    "# ============================================================\n",
    "# PHASE 1 — FY2011 BROAD SCAN\n",
    "# ============================================================\n",
    "print(\"=\" * 72)\n",
    "print(\"PHASE 1: FY2011 BROAD SCAN\")\n",
    "print(\"=\" * 72)\n",
    "\n",
    "nmrc = load_nmrc(BASE_DIR / \"HOSP10FY2011\" / \"hosp10_2011_NMRC.CSV\")\n",
    "print(f\"FY2011: {len(nmrc):,} rows loaded\\n\")\n",
    "\n",
    "# --- CONTRACT LABOR ---\n",
    "# On 2552-10, Worksheet A line 20000 summary columns we already know:\n",
    "#   00100=salaries, 00200=sal+ben, 00300=total exp, 00700=net of adj\n",
    "# Contract labor / registry typically in col 00400 or col 00600\n",
    "# Also check A820010 (physician) and nearby lines on A000000\n",
    "\n",
    "print(\"--- A000000 / line 20000: all columns (finding contract labor) ---\")\n",
    "sub = nmrc[\n",
    "    (nmrc[\"WKSHT_CD\"] == \"A000000\") &\n",
    "    (nmrc[\"LINE_NUM\"]  == \"20000\") &\n",
    "    (nmrc[\"ITM_VAL_NUM\"].abs() > 1000)\n",
    "]\n",
    "grp = (\n",
    "    sub.groupby(\"CLMN_NUM\")[\"ITM_VAL_NUM\"]\n",
    "    .agg(hosp_count=(\"nunique\"), median=\"median\", max=\"max\")\n",
    "    .sort_values(\"hosp_count\", ascending=False)\n",
    ")\n",
    "print(grp.to_string())\n",
    "print()\n",
    "\n",
    "# Check A000000 lines near 20000 that may carry contract labor subtotals\n",
    "print(\"--- A000000 lines 19500–20500: candidates with 1000+ hospitals, $100K+ ---\")\n",
    "lo, hi = \"19500\", \"20500\"\n",
    "sub2 = nmrc[\n",
    "    (nmrc[\"WKSHT_CD\"] == \"A000000\") &\n",
    "    (nmrc[\"LINE_NUM\"] >= lo) & (nmrc[\"LINE_NUM\"] <= hi) &\n",
    "    (nmrc[\"ITM_VAL_NUM\"] >= 100_000)\n",
    "]\n",
    "grp2 = (\n",
    "    sub2.groupby([\"LINE_NUM\",\"CLMN_NUM\"])\n",
    "    .agg(hosp_count=(\"RPT_REC_NUM\",\"nunique\"), median_val=(\"ITM_VAL_NUM\",\"median\"))\n",
    "    .reset_index()\n",
    "    .query(\"hosp_count >= 1000\")\n",
    "    .sort_values(\"hosp_count\", ascending=False)\n",
    ")\n",
    "print(grp2.head(20).to_string(index=False))\n",
    "print()\n",
    "\n",
    "# --- BUDGETED / LICENSED FTEs ---\n",
    "print(\"--- S300001 line 02700: ALL columns ---\")\n",
    "sub3 = nmrc[\n",
    "    (nmrc[\"WKSHT_CD\"] == \"S300001\") &\n",
    "    (nmrc[\"LINE_NUM\"]  == \"02700\") &\n",
    "    (nmrc[\"ITM_VAL_NUM\"].abs() > 0)\n",
    "]\n",
    "grp3 = (\n",
    "    sub3.groupby(\"CLMN_NUM\")[\"ITM_VAL_NUM\"]\n",
    "    .agg(hosp_count=\"nunique\", median=\"median\", max=\"max\")\n",
    "    .sort_values(\"hosp_count\", ascending=False)\n",
    ")\n",
    "print(grp3.to_string())\n",
    "print()\n",
    "\n",
    "# Check adjacent S lines for budgeted positions\n",
    "print(\"--- S300001 lines 02600–03000: cols with 1000+ hospitals, 10–100000 range ---\")\n",
    "sub4 = nmrc[\n",
    "    (nmrc[\"WKSHT_CD\"] == \"S300001\") &\n",
    "    (nmrc[\"LINE_NUM\"] >= \"02600\") & (nmrc[\"LINE_NUM\"] <= \"03000\") &\n",
    "    (nmrc[\"ITM_VAL_NUM\"] >= 10) & (nmrc[\"ITM_VAL_NUM\"] <= 100_000)\n",
    "]\n",
    "grp4 = (\n",
    "    sub4.groupby([\"LINE_NUM\",\"CLMN_NUM\"])\n",
    "    .agg(hosp_count=(\"RPT_REC_NUM\",\"nunique\"), median_val=(\"ITM_VAL_NUM\",\"median\"))\n",
    "    .reset_index()\n",
    "    .query(\"hosp_count >= 500\")\n",
    "    .sort_values(\"hosp_count\", ascending=False)\n",
    ")\n",
    "print(grp4.head(20).to_string(index=False))\n",
    "print()\n",
    "\n",
    "# ============================================================\n",
    "# PHASE 2 — MULTI-YEAR VERIFICATION\n",
    "# Update CANDIDATES below after reviewing Phase 1 output\n",
    "# ============================================================\n",
    "print(\"=\" * 72)\n",
    "print(\"PHASE 2: MULTI-YEAR VERIFICATION\")\n",
    "print(\"=\" * 72)\n",
    "\n",
    "# Best guesses from 2552-10 form structure — Phase 1 will confirm\n",
    "CANDIDATES = {\n",
    "    \"contract_labor\": [\n",
    "        (\"A000000\", \"20000\", \"00400\"),  # contract/registry labor column\n",
    "        (\"A000000\", \"20000\", \"00600\"),  # adjustment column — may be contract\n",
    "    ],\n",
    "    \"budgeted_ftes\": [\n",
    "        (\"S300001\", \"02700\", \"00200\"),  # Phase 1 showed median 89 — plausible\n",
    "        (\"S300001\", \"02700\", \"00300\"),  # another FTE column candidate\n",
    "        (\"S300001\", \"02800\", \"01000\"),  # budgeted positions — adjacent line\n",
    "        (\"S300001\", \"02800\", \"00200\"),  # alternative column on 02800\n",
    "    ],\n",
    "}\n",
    "\n",
    "all_results = []\n",
    "\n",
    "for field, addresses in CANDIDATES.items():\n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(f\"  {field.upper()}\")\n",
    "    print(f\"{'='*60}\")\n",
    "    min_val = 10 if field == \"budgeted_ftes\" else 100_000\n",
    "\n",
    "    for ws, line, col in addresses:\n",
    "        print(f\"\\n  {ws} / line {line} / col {col}\")\n",
    "        print(f\"  {'Year':<8} {'Hospitals':>10} {'Median':>18}\")\n",
    "        print(f\"  {'-'*8} {'-'*10} {'-'*18}\")\n",
    "\n",
    "        year_results = []\n",
    "        for year in YEARS:\n",
    "            nmrc_file = BASE_DIR / f\"HOSP10FY{year}\" / f\"hosp10_{year}_NMRC.CSV\"\n",
    "            if not nmrc_file.exists():\n",
    "                continue\n",
    "            nmrc_y = load_nmrc(nmrc_file)\n",
    "            n, med, mx = probe(nmrc_y, ws, line, col, min_val=min_val)\n",
    "            med_str = f\"{med:>18,.1f}\" if med is not None else \"               ---\"\n",
    "            print(f\"  FY{year}   {n:>10,} {med_str}\")\n",
    "            year_results.append({\"year\": year, \"field\": field,\n",
    "                                  \"ws\": ws, \"line\": line, \"col\": col,\n",
    "                                  \"hosp_count\": n, \"median\": med})\n",
    "\n",
    "        all_results.append(pd.DataFrame(year_results))\n",
    "\n",
    "# Save results\n",
    "if all_results:\n",
    "    out_df = pd.concat(all_results, ignore_index=True)\n",
    "    csv_path = OUTPUT_DIR / \"contract_budgeted_mapping_matrix.csv\"\n",
    "    out_df.to_csv(csv_path, index=False)\n",
    "    print(f\"\\n\\nResults saved → {csv_path}\")\n",
    "\n",
    "print(\"\\nSniffer complete.\")"
   ]
  },
