    "## 3b.  Trend Table"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "01d45259-67a7-4bce-a9f2-816ca1442e3e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
