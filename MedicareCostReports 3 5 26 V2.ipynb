    "import pandas as pd\n",
    "import numpy as np\n",
    "from pathlib import Path\n",
    "\n",
    "BASE_DIR = Path(r\"/mnt/c/Users/lfult/OneDrive - bc.edu/Desktop/CMS Cost Reports\")\n",
    "\n",
    "def sniff_delimiter(filepath):\n",
    "    with open(filepath, \"r\", encoding=\"latin1\", errors=\"replace\") as f:\n",
    "        line = f.readline()\n",
    "    counts = {\",\": line.count(\",\"), \"\\t\": line.count(\"\\t\"), \"|\": line.count(\"|\")}\n",
    "    return max(counts, key=counts.get)\n",
    "\n",
    "def load_nmrc(filepath):\n",
    "    sep = sniff_delimiter(filepath)\n",
    "    df = pd.read_csv(filepath, sep=sep, header=None,\n",
    "        names=[\"RPT_REC_NUM\",\"WKSHT_CD\",\"LINE_NUM\",\"CLMN_NUM\",\"ITM_VAL_NUM\"],\n",
    "        encoding=\"latin1\", low_memory=False, dtype=str)\n",
    "    df[\"RPT_REC_NUM\"] = df[\"RPT_REC_NUM\"].astype(str).str.strip()\n",
    "    df[\"WKSHT_CD\"]    = df[\"WKSHT_CD\"].astype(str).str.strip()\n",
    "    df[\"LINE_NUM\"]    = df[\"LINE_NUM\"].astype(str).str.strip().str.zfill(5)\n",
    "    df[\"CLMN_NUM\"]    = df[\"CLMN_NUM\"].astype(str).str.strip().str.zfill(5)\n",
    "    df[\"ITM_VAL_NUM\"] = pd.to_numeric(df[\"ITM_VAL_NUM\"], errors=\"coerce\")\n",
    "    return df\n",
    "\n",
    "nmrc = load_nmrc(BASE_DIR / \"HOSP10FY2011\" / \"hosp10_2011_NMRC.CSV\")\n",
    "\n",
    "# === PROBE 1: SNF days — looking for thousands range, 1000+ hospitals ===\n",
    "print(\"=== SNF DAYS — S worksheet, line 01900, all columns ===\")\n",
    "sub = nmrc[\n",
    "    nmrc[\"WKSHT_CD\"].str.startswith(\"S\") &\n",
    "    (nmrc[\"LINE_NUM\"] == \"01900\") &\n",
    "    (nmrc[\"ITM_VAL_NUM\"] >= 100) &\n",
    "    (nmrc[\"ITM_VAL_NUM\"] <= 500_000)\n",
    "]\n",
    "grp = (sub.groupby([\"WKSHT_CD\",\"CLMN_NUM\"])\n",
    "    .agg(hosp_count=(\"RPT_REC_NUM\",\"nunique\"),\n",
    "         median_val=(\"ITM_VAL_NUM\",\"median\"),\n",
    "         max_val=(\"ITM_VAL_NUM\",\"max\"))\n",
    "    .reset_index().sort_values(\"hosp_count\", ascending=False).head(15))\n",
    "print(grp.to_string(index=False))\n",
    "\n",
    "# === PROBE 2: ICU days — looking for hundreds range, 2000+ hospitals ===\n",
    "print(\"\\n=== ICU DAYS — S worksheet, line 01500, plausible day counts ===\")\n",
    "sub2 = nmrc[\n",
    "    nmrc[\"WKSHT_CD\"].str.startswith(\"S\") &\n",
    "    (nmrc[\"LINE_NUM\"] == \"01500\") &\n",
    "    (nmrc[\"ITM_VAL_NUM\"] >= 10) &\n",
    "    (nmrc[\"ITM_VAL_NUM\"] <= 200_000)\n",
    "]\n",
    "grp2 = (sub2.groupby([\"WKSHT_CD\",\"CLMN_NUM\"])\n",
    "    .agg(hosp_count=(\"RPT_REC_NUM\",\"nunique\"),\n",
    "         median_val=(\"ITM_VAL_NUM\",\"median\"),\n",
    "         max_val=(\"ITM_VAL_NUM\",\"max\"))\n",
    "    .reset_index().sort_values(\"hosp_count\", ascending=False).head(15))\n",
    "print(grp2.to_string(index=False))\n",
    "\n",
    "# === PROBE 3: ER visits — broad S scan, lines 01200-01400 ===\n",
    "print(\"\\n=== ER VISITS — S worksheet, lines 01200-01400, 1000-5M range ===\")\n",
    "sub3 = nmrc[\n",
    "    nmrc[\"WKSHT_CD\"].str.startswith(\"S\") &\n",
    "    (nmrc[\"LINE_NUM\"] >= \"01200\") & (nmrc[\"LINE_NUM\"] <= \"01400\") &\n",
    "    (nmrc[\"ITM_VAL_NUM\"] >= 1_000) &\n",
    "    (nmrc[\"ITM_VAL_NUM\"] <= 5_000_000)\n",
    "]\n",
    "grp3 = (sub3.groupby([\"WKSHT_CD\",\"LINE_NUM\",\"CLMN_NUM\"])\n",
    "    .agg(hosp_count=(\"RPT_REC_NUM\",\"nunique\"),\n",
    "         median_val=(\"ITM_VAL_NUM\",\"median\"),\n",
    "         max_val=(\"ITM_VAL_NUM\",\"max\"))\n",
    "    .reset_index()\n",
    "    .query(\"hosp_count >= 1000\")\n",
    "    .sort_values(\"hosp_count\", ascending=False).head(20))\n",
    "print(grp3.to_string(index=False))"
   ]
