   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import DataLoader, TensorDataset\n",
    "\n",
    "from sklearn.impute import SimpleImputer\n",
    "from sklearn.preprocessing import RobustScaler\n",
    "from sklearn.metrics import roc_auc_score, average_precision_score\n",
    "from scipy.stats import spearmanr\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "# ROBUST VAE FORENSICS + SRRI DV (Strategic Reporting Risk Index)\n",
    "# - builds submission_type + status_severity (for context, not DV)\n",
    "# - builds SRRI (new DV proxy) from your engineered forensic signals\n",
    "# - trains VAE on LOW_SCRUTINY, with a norm filter (anti-poisoning)\n",
    "# - scores all rows: vae_gaming_score + components\n",
    "# - evaluates VAE vs SRRI (Spearman + AUC/AP vs top-10% SRRI)\n",
    "# - generates top leads + consensus leads (VAE ∩ SRRI)\n",
    "# ============================================================\n",
    "\n",
    "# -----------------------------\n",
    "# 0) Repro + helpers\n",
    "# -----------------------------\n",
    "SEED = 42\n",
    "np.random.seed(SEED)\n",
    "torch.manual_seed(SEED)\n",
    "torch.cuda.manual_seed_all(SEED)\n",
    "\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "print(\"Device:\", device)\n",
    "\n",
    "def signed_log(x):\n",
    "    \"\"\"Compresses massive dollar ranges while preserving sign.\"\"\"\n",
    "    x = pd.to_numeric(x, errors=\"coerce\")\n",
    "    return np.sign(x) * np.log1p(np.abs(x))\n",
    "\n",
    "def pct_rank(s: pd.Series) -> pd.Series:\n",
    "    return pd.to_numeric(s, errors=\"coerce\").rank(pct=True, method=\"average\")\n",
    "\n",
    "def winsorize_series(s: pd.Series, lo=0.01, hi=0.99) -> pd.Series:\n",
    "    x = pd.to_numeric(s, errors=\"coerce\")\n",
    "    if x.notna().sum() == 0:\n",
    "        return x\n",
    "    ql, qh = x.quantile(lo), x.quantile(hi)\n",
    "    return x.clip(ql, qh)\n",
    "\n",
    "# -----------------------------\n",
    "# 1) Submission lifecycle variables (context only)\n",
    "# -----------------------------\n",
    "status_map = {\n",
    "    \"1\": \"Original_As_Submitted\",\n",
    "    \"2\": \"Settled_No_Audit\",\n",
    "    \"3\": \"Settled_With_Audit\",\n",
    "    \"4\": \"Reopened\",\n",
    "    \"5\": \"Amended\",\n",
    "}\n",
    "\n",
    "df = df.copy()\n",
    "df[\"submission_type\"] = df[\"RPT_STUS_CD\"].astype(str).map(status_map)\n",
    "\n",
    "status_severity = {\n",
    "    \"Original_As_Submitted\": 0,\n",
    "    \"Settled_No_Audit\": 1,\n",
    "    \"Settled_With_Audit\": 2,\n",
    "    \"Reopened\": 3,\n",
    "    \"Amended\": 4,\n",
    "}\n",
    "df[\"status_severity\"] = df[\"submission_type\"].map(status_severity)\n",
    "\n",
    "# -----------------------------\n",
    "# 2) Build SRRI (NEW DV proxy)\n",
    "# -----------------------------\n",
    "# SRRI is a latent \"strategic reporting risk\" construct from your forensic channels.\n",
    "# It is NOT \"fraud\". It is an internally-consistent risk proxy.\n",
    "components = {}\n",
    "\n",
    "# (Add whichever of these exist in your df)\n",
    "if \"mahal_relational_score\" in df.columns:\n",
    "    components[\"relational_break\"] = pct_rank(df[\"mahal_relational_score\"])\n",
    "\n",
    "if \"decoupling_index\" in df.columns:\n",
    "    components[\"decoupling\"] = pct_rank(df[\"decoupling_index\"].abs())\n",
    "\n",
    "if \"pct_measures_improving\" in df.columns:\n",
    "    components[\"coord_improve\"] = pct_rank(df[\"pct_measures_improving\"])\n",
    "\n",
    "if \"bunch_signal_operating_margin\" in df.columns:\n",
    "    components[\"bunching\"] = pct_rank(df[\"bunch_signal_operating_margin\"])\n",
    "\n",
    "if \"tslf\" in df.columns:\n",
    "    components[\"persistence\"] = pct_rank(df[\"tslf\"])\n",
    "\n",
    "if \"benford_anomaly_score\" in df.columns:\n",
    "    components[\"digit_anomaly\"] = pct_rank(df[\"benford_anomaly_score\"])\n",
    "\n",
    "# If you have additional engineered features from your extended block, include them automatically:\n",
    "OPTIONAL_SRRI_COLS = [\n",
    "    (\"peer_divergence_year\", \"peer_divergence\"),\n",
    "    (\"rank_instability_mean\", \"rank_volatility\"),\n",
    "    (\"path_step_norm\", \"trajectory_jump\"),\n",
    "]\n",
    "for raw_col, alias in OPTIONAL_SRRI_COLS:\n",
    "    if raw_col in df.columns:\n",
    "        components[alias] = pct_rank(df[raw_col])\n",
    "\n",
    "if len(components) < 3:\n",
    "    raise ValueError(\n",
    "        f\"SRRI needs at least ~3 component columns; found {list(components.keys())}. \"\n",
    "        \"Add more signals (mahal_relational_score, decoupling_index, bunch_signal_operating_margin, tslf, etc.).\"\n",
    "    )\n",
    "\n",
    "comp_df = pd.DataFrame(components, index=df.index).clip(upper=0.98)\n",
    "\n",
    "df[\"srri_base\"] = comp_df.mean(axis=1)\n",
    "\n",
    "# Bonus emphasizes persistent + coordinated improvement (classic gaming signature)\n",
    "bonus = (\n",
    "    0.5 * comp_df.get(\"persistence\", 0) +\n",
    "    0.5 * comp_df.get(\"coord_improve\", 0)\n",
    ") / 2.0\n",
    "\n",
    "df[\"srri_bonus\"] = bonus.fillna(0)\n",
    "df[\"SRRI\"] = 100.0 * (0.8 * df[\"srri_base\"] + 0.2 * df[\"srri_bonus\"])\n",
    "df[\"SRRI_pct\"] = pct_rank(df[\"SRRI\"])\n",
    "\n",
    "print(\"\\nSRRI components used:\", list(comp_df.columns))\n",
    "print(df[\"SRRI\"].describe(percentiles=[0.5, 0.9, 0.95, 0.99]))\n",
    "\n",
    "# -----------------------------\n",
    "# 3) Robust preprocessing for VAE (\"De-Noiser\")\n",
    "# -----------------------------\n",
    "# We create a clean training copy\n",
    "df_vae = df.copy()\n",
    "\n",
    "# A: Apply Signed Log to high-variance forensic features\n",
    "cols_to_log = [\n",
    "    c for c in FORENSIC_FEATURES\n",
    "    if any(sub in c for sub in [\"rev\", \"exp\", \"asset\", \"mahal\", \"path\"])\n",
    "]\n",
    "for c in cols_to_log:\n",
    "    if c in df_vae.columns:\n",
    "        df_vae[c] = signed_log(df_vae[c])\n",
    "\n",
    "# B: Impute and Scale\n",
    "missing = [c for c in FORENSIC_FEATURES if c not in df_vae.columns]\n",
    "if missing:\n",
    "    raise ValueError(f\"Missing {len(missing)} FORENSIC_FEATURES: {missing[:10]}{'...' if len(missing)>10 else ''}\")\n",
    "\n",
    "imp = SimpleImputer(strategy=\"median\")\n",
    "scaler = RobustScaler()\n",
    "\n",
    "X_raw = imp.fit_transform(df_vae[FORENSIC_FEATURES])\n",
    "X_scaled = scaler.fit_transform(X_raw)\n",
    "\n",
    "# Hard-cap Z-scores at +/- 10 to prevent leverage/gradient issues\n",
    "X_scaled = np.clip(X_scaled, -10, 10).astype(np.float32)\n",
    "\n",
    "# Keep finite rows only (important)\n",
    "finite_mask = np.isfinite(X_scaled).all(axis=1)\n",
    "idx_f = df_vae.index[finite_mask]\n",
    "X_scaled_f = X_scaled[finite_mask]\n",
    "X_tensor = torch.from_numpy(X_scaled_f)\n",
    "\n",
    "print(\"\\nFinite VAE rows:\", len(idx_f), \"/\", len(df_vae))\n",
    "\n",
    "# -----------------------------\n",
    "# 4) Define Training Pool (LOW SCRUTINY) + anti-poison norm filter\n",
    "# -----------------------------\n",
    "LOW_SCRUTINY = {\"Original_As_Submitted\", \"Settled_No_Audit\"}\n",
    "stype_f = df_vae.loc[idx_f, \"submission_type\"]\n",
    "low_mask = stype_f.isin(LOW_SCRUTINY).fillna(False).values\n",
    "\n",
    "# Norm filter: excludes extreme feature-space rows from training even if \"low scrutiny\"\n",
    "row_norm = np.sqrt((X_scaled_f**2).sum(axis=1))\n",
    "rn = pd.Series(row_norm, index=idx_f)\n",
    "mad = (rn - rn.median()).abs().median()\n",
    "rn_z = (rn - rn.median()) / (1.4826 * mad + 1e-9)\n",
    "norm_ok = (rn_z <= 6.0).values\n",
    "\n",
    "train_mask = low_mask & norm_ok\n",
    "X_train = X_tensor[train_mask]\n",
    "\n",
    "if len(X_train) < 1000:\n",
    "    print(\"WARNING: very small training pool after filters; relaxing norm filter to rn_z<=8.\")\n",
    "    train_mask = low_mask & (rn_z <= 8.0).values\n",
    "    X_train = X_tensor[train_mask]\n",
    "\n",
    "print(f\"Training on {len(X_train)} LOW_SCRUTINY + norm_ok records...\")\n",
    "\n",
    "train_loader = DataLoader(\n",
    "    TensorDataset(X_train),\n",
    "    batch_size=256,\n",
    "    shuffle=True,\n",
    "    drop_last=True  # helps BatchNorm stability\n",
    ")\n",
    "\n",
    "# -----------------------------\n",
    "# 5) Architecture: Stabilized VAE\n",
    "# -----------------------------\n",
    "class RobustForensicVAE(nn.Module):\n",
    "    def __init__(self, input_dim, latent_dim=4):\n",
    "        super().__init__()\n",
    "        self.encoder = nn.Sequential(\n",
    "            nn.Linear(input_dim, 32),\n",
    "            nn.BatchNorm1d(32),\n",
    "            nn.LeakyReLU(0.2),\n",
    "            nn.Linear(32, 16),\n",
    "            nn.LeakyReLU(0.2),\n",
    "        )\n",
    "        self.fc_mu = nn.Linear(16, latent_dim)\n",
    "        self.fc_logvar = nn.Linear(16, latent_dim)\n",
    "\n",
    "        self.decoder = nn.Sequential(\n",
    "            nn.Linear(latent_dim, 16),\n",
    "            nn.LeakyReLU(0.2),\n",
    "            nn.Linear(16, 32),\n",
    "            nn.LeakyReLU(0.2),\n",
    "            nn.Linear(32, input_dim),\n",
    "        )\n",
    "\n",
    "    def encode(self, x):\n",
    "        h = self.encoder(x)\n",
    "        mu = self.fc_mu(h)\n",
    "        logvar = self.fc_logvar(h).clamp(-5, 5)\n",
    "        return mu, logvar\n",
    "\n",
    "    def reparameterize(self, mu, logvar):\n",
    "        std = torch.exp(0.5 * logvar)\n",
    "        return mu + torch.randn_like(std) * std\n",
    "\n",
    "    def forward(self, x):\n",
    "        mu, logvar = self.encode(x)\n",
    "        z = self.reparameterize(mu, logvar)\n",
    "        return self.decoder(z), mu, logvar\n",
    "\n",
    "# -----------------------------\n",
    "# 6) Robust Loss (Huber) + KL annealing\n",
    "# -----------------------------\n",
    "def robust_vae_loss(x, xhat, mu, logvar, beta=0.01):\n",
    "    recon_loss = nn.functional.huber_loss(xhat, x, reduction=\"mean\", delta=1.0)\n",
    "    kl_loss = -0.5 * torch.mean(torch.sum(1 + logvar - mu.pow(2) - logvar.exp(), dim=1))\n",
    "    return recon_loss + (beta * kl_loss), recon_loss, kl_loss\n",
    "\n",
    "model = RobustForensicVAE(input_dim=len(FORENSIC_FEATURES)).to(device)\n",
    "optimizer = optim.AdamW(model.parameters(), lr=1e-3, weight_decay=1e-4)\n",
    "\n",
    "# -----------------------------\n",
    "# 7) Training Loop (report epoch means)\n",
    "# -----------------------------\n",
    "EPOCHS = 50\n",
    "for epoch in range(EPOCHS):\n",
    "    model.train()\n",
    "    beta = 0.05 * min(1.0, epoch / 25)  # anneal KL in\n",
    "\n",
    "    losses, recons, kls = [], [], []\n",
    "    for (xb,) in train_loader:\n",
    "        xb = xb.to(device)\n",
    "        optimizer.zero_grad()\n",
    "        xhat, mu, logvar = model(xb)\n",
    "        loss, recon, kl = robust_vae_loss(xb, xhat, mu, logvar, beta=beta)\n",
    "        loss.backward()\n",
    "        nn.utils.clip_grad_norm_(model.parameters(), 5.0)\n",
    "        optimizer.step()\n",
    "        losses.append(loss.item()); recons.append(recon.item()); kls.append(kl.item())\n",
    "\n",
    "    if epoch % 10 == 0 or epoch == EPOCHS - 1:\n",
    "        print(f\"Epoch {epoch:02d} | beta={beta:.3f} | loss={np.mean(losses):.4f} | recon={np.mean(recons):.4f} | kl={np.mean(kls):.4f}\")\n",
    "\n",
    "# -----------------------------\n",
    "# 8) Scoring: VAE anomaly scores (finite rows)\n",
    "# -----------------------------\n",
    "model.eval()\n",
    "with torch.no_grad():\n",
    "    xb = X_tensor.to(device)\n",
    "    xhat, mu, logvar = model(xb)\n",
    "\n",
    "    # Per-row reconstruction magnitude\n",
    "    recon_errors = torch.norm(xb - xhat, dim=1).detach().cpu().numpy()\n",
    "    kl_errors = (-0.5 * torch.sum(1 + logvar - mu.pow(2) - logvar.exp(), dim=1)).detach().cpu().numpy()\n",
    "\n",
    "vae_score = recon_errors + (0.05 * kl_errors)\n",
    "\n",
    "# Attach back to df (finite rows only)\n",
    "df[\"vae_gaming_score\"] = np.nan\n",
    "df[\"vae_recon_only\"] = np.nan\n",
    "df[\"vae_kl_only\"] = np.nan\n",
    "\n",
    "df.loc[idx_f, \"vae_gaming_score\"] = vae_score\n",
    "df.loc[idx_f, \"vae_recon_only\"] = recon_errors\n",
    "df.loc[idx_f, \"vae_kl_only\"] = kl_errors\n",
    "\n",
    "# -----------------------------\n",
    "# 9) Evaluation: VAE vs SRRI (NEW DV)\n",
    "# -----------------------------\n",
    "tmp = df.dropna(subset=[\"vae_gaming_score\", \"SRRI\"])\n",
    "rho, p = spearmanr(tmp[\"vae_gaming_score\"].values, tmp[\"SRRI\"].values)\n",
    "print(f\"\\nSpearman(VAE, SRRI): rho={rho:.3f}, p={p:.3g}\")\n",
    "\n",
    "# AUC/AP: treat top-10% SRRI as \"positives\" (risk band)\n",
    "thr = tmp[\"SRRI\"].quantile(0.90)\n",
    "y = (tmp[\"SRRI\"] >= thr).astype(int).values\n",
    "\n",
    "auc = roc_auc_score(y, tmp[\"vae_gaming_score\"].values)\n",
    "ap = average_precision_score(y, tmp[\"vae_gaming_score\"].values)\n",
    "\n",
    "print(f\"AUC vs top-10% SRRI: {auc:.3f} | AP: {ap:.3f}\")\n",
    "\n",
    "# -----------------------------\n",
    "# 10) Consensus lead generation (VAE ∩ SRRI)\n",
    "# -----------------------------\n",
    "eps = 1e-9\n",
    "df[\"vae_pct\"] = df[\"vae_gaming_score\"].rank(pct=True, method=\"average\")\n",
    "df[\"consensus_score\"] = 0.5 * df[\"vae_pct\"].fillna(0) + 0.5 * df[\"SRRI_pct\"].fillna(0)\n",
    "#df[\"consensus_strict\"] = df[\"vae_pct\"].fillna(0) * df[\"SRRI_pct\"].fillna(0)\n",
    "df[\"consensus_tail\"] = -np.log((1 - df[\"vae_pct\"] + eps) * (1 - df[\"SRRI_pct\"] + eps))\n",
    "\n",
    "top_vae = df.sort_values(\"vae_gaming_score\", ascending=False).head(20)\n",
    "top_srri = df.sort_values(\"SRRI\", ascending=False).head(20)\n",
    "top_consensus = df.sort_values(\"consensus_tail\", ascending=False).head(30)\n",
    "\n",
    "print(\"\\n--- TOP 20 VAE LEADS ---\")\n",
    "show_cols = [\"PRVDR_NUM\", \"source_year\", \"submission_type\", \"vae_gaming_score\", \"SRRI\", \"consensus_tail\"]\n",
    "if \"outlier_flags\" in df.columns:\n",
    "    show_cols += [\"outlier_flags\"]\n",
    "print(top_vae[show_cols])\n",
    "\n",
    "print(\"\\n--- TOP 20 SRRI LEADS ---\")\n",
    "print(top_srri[show_cols])\n",
    "\n",
    "print(\"\\n--- TOP 30 CONSENSUS (STRICT) LEADS ---\")\n",
    "print(top_consensus[show_cols])\n",
    "\n",
    "df[\"VAE_high\"] = df[\"vae_pct\"] >= 0.90\n",
    "df[\"SRRI_high\"] = df[\"SRRI_pct\"] >= 0.90\n",
    "\n",
    "df[\"anomaly_quadrant\"] = np.select(\n",
    "    [\n",
    "        df[\"VAE_high\"] & df[\"SRRI_high\"],\n",
    "        df[\"VAE_high\"] & ~df[\"SRRI_high\"],\n",
    "        ~df[\"VAE_high\"] & df[\"SRRI_high\"],\n",
    "    ],\n",
    "    [\n",
    "        \"CONSENSUS_HIGH\",\n",
    "        \"VAE_ONLY_STRUCTURAL\",\n",
    "        \"SRRI_ONLY_RULELIKE\",\n",
    "    ],\n",
    "    default=\"LOW\"\n",
    ")\n",
    "\n",
    "print(df[\"anomaly_quadrant\"].value_counts(dropna=False))"
   ]
  },
