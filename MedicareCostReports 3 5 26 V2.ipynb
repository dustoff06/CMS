    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# Top-10 tables for \"CRITICAL: Structural, Behavioral, and Shock Anomalies\"\n",
    "#  (1) Facility-year (can repeat PRVDR_NUM across years)\n",
    "#  (2) Unique facility (top year per PRVDR_NUM, then top 10 PRVDR_NUM)\n",
    "#  Professional forensics formatting + nice display\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "CRIT_LABEL = \"CRITICAL: Structural, Behavioral, and Shock Anomalies\"\n",
    "\n",
    "# --- Pick a reasonable facility-name column if it exists ---\n",
    "NAME_CANDIDATES = [\n",
    "    \"provider_name\", \"PROVIDER_NAME\", \"fac_name\", \"facility_name\", \"hosp_name\",\n",
    "    \"hospital_name\", \"prvdr_name\", \"name\", \"provider_nm\"\n",
    "]\n",
    "name_col = next((c for c in NAME_CANDIDATES if c in df.columns), None)\n",
    "\n",
    "# --- Columns we’d like to show (only keep those that exist) ---\n",
    "base_cols = [\"PRVDR_NUM\", \"source_year\"]\n",
    "if name_col:\n",
    "    base_cols.insert(1, name_col)\n",
    "\n",
    "score_cols = [\"risk_fused\", \"vae_pct\", \"srri_pct\", \"if_pct\", \"anomaly_score\", \"vae_gaming_score\", \"SRRI\"]\n",
    "explain_cols = [\"outlier_flags\", \"outlier_drivers_top\"]\n",
    "\n",
    "def _keep_existing(cols):\n",
    "    return [c for c in cols if c in df.columns]\n",
    "\n",
    "show_cols = _keep_existing(base_cols + score_cols + explain_cols)\n",
    "\n",
    "# --- Filter critical set ---\n",
    "crit = df.loc[df[\"risk_category\"] == CRIT_LABEL].copy()\n",
    "\n",
    "if crit.empty:\n",
    "    raise ValueError(f\"No rows found with risk_category == '{CRIT_LABEL}'. Check labels or classification step.\")\n",
    "\n",
    "# --- Helper: styling for professional readout ---\n",
    "def _style_forensics(t: pd.DataFrame, title: str):\n",
    "    t2 = t.copy()\n",
    "\n",
    "    # Friendly numeric formats (percentiles as percent, scores as 3 decimals)\n",
    "    pct_cols = [c for c in [\"vae_pct\", \"srri_pct\", \"if_pct\"] if c in t2.columns]\n",
    "    score3_cols = [c for c in [\"risk_fused\", \"anomaly_score\", \"vae_gaming_score\", \"SRRI\"] if c in t2.columns]\n",
    "\n",
    "    # If percentiles are 0–1, keep; if 0–100, still works visually but will look huge\n",
    "    fmt = {}\n",
    "    for c in pct_cols:\n",
    "        fmt[c] = \"{:.1%}\"\n",
    "    for c in score3_cols:\n",
    "        fmt[c] = \"{:.3f}\"\n",
    "\n",
    "    # Shorten very long driver strings (optional)\n",
    "    if \"outlier_drivers_top\" in t2.columns:\n",
    "        t2[\"outlier_drivers_top\"] = t2[\"outlier_drivers_top\"].astype(str).replace(\"nan\", \"\")\n",
    "        t2[\"outlier_drivers_top\"] = t2[\"outlier_drivers_top\"].str.slice(0, 220)\n",
    "\n",
    "    sty = (\n",
    "        t2.style\n",
    "        .set_caption(title)\n",
    "        .format(fmt, na_rep=\"\")\n",
    "        .set_properties(**{\"white-space\": \"pre-wrap\"})\n",
    "    )\n",
    "\n",
    "    # Highlight high fused risk\n",
    "    if \"risk_fused\" in t2.columns:\n",
    "        sty = sty.background_gradient(subset=[\"risk_fused\"], cmap=\"Reds\")\n",
    "\n",
    "    return sty\n",
    "\n",
    "# ============================================================\n",
    "# (1) TOP-10 FACILITY-YEAR (may repeat PRVDR_NUM)\n",
    "# ============================================================\n",
    "top10_facility_year = (\n",
    "    crit.sort_values([\"risk_fused\", \"srri_pct\", \"vae_pct\", \"if_pct\"], ascending=False)\n",
    "        .head(10)[show_cols]\n",
    ")\n",
    "\n",
    "display(_style_forensics(\n",
    "    top10_facility_year,\n",
    "    \"Top 10 CRITICAL Triple-Threat Outliers (Facility-Year, ranked by fused risk)\"\n",
    "))\n",
    "\n",
    "# ============================================================\n",
    "# (2) TOP-10 UNIQUE FACILITIES (best year per PRVDR_NUM)\n",
    "# ============================================================\n",
    "# Pick the single most severe year for each PRVDR_NUM, then take top 10 facilities\n",
    "top10_unique_facilities = (\n",
    "    crit.sort_values([\"risk_fused\", \"srri_pct\", \"vae_pct\", \"if_pct\"], ascending=False)\n",
    "        .drop_duplicates(subset=[\"PRVDR_NUM\"], keep=\"first\")\n",
    "        .head(10)[show_cols]\n",
    ")\n",
    "\n",
    "display(_style_forensics(\n",
    "    top10_unique_facilities,\n",
    "    \"Top 10 CRITICAL Triple-Threat Outliers (Unique facilities, best year per PRVDR_NUM)\"\n",
    "))\n",
    "\n",
    "# Optional: if you want to export for later reporting\n",
    "# top10_facility_year.to_csv(\"top10_critical_facility_year.csv\", index=False)\n",
    "# top10_unique_facilities.to_csv(\"top10_critical_unique_facilities.csv\", index=False)"
   ]
