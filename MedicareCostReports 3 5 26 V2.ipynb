   "source": [
    "# For FY2011, show ALL E-worksheet candidates for line 03300\n",
    "# sorted by median value descending (not hospital count)\n",
    "\n",
    "e_dsh = nmrc[\n",
    "    nmrc[\"WKSHT_CD\"].str.startswith(\"E\") &\n",
    "    (nmrc[\"LINE_NUM\"] == \"03300\") &\n",
    "    (nmrc[\"ITM_VAL_NUM\"].abs() > 1_000)\n",
    "].copy()\n",
    "\n",
    "grp = (\n",
    "    e_dsh.groupby([\"WKSHT_CD\", \"CLMN_NUM\"])\n",
    "    .agg(\n",
    "        hosp_count=(\"RPT_REC_NUM\", \"nunique\"),\n",
    "        median_val=(\"ITM_VAL_NUM\", \"median\"),\n",
    "        mean_val=(\"ITM_VAL_NUM\", \"mean\"),\n",
    "        max_val=(\"ITM_VAL_NUM\", \"max\"),\n",
    "        total=(\"ITM_VAL_NUM\", \"sum\"),\n",
    "    )\n",
    "    .reset_index()\n",
    "    .sort_values(\"median_val\", ascending=False)  # sort by magnitude, not count\n",
    ")\n",
    "print(grp.to_string())"
   ]
