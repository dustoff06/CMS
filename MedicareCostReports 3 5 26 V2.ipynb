   "source": [
    "# Pull the actual S3 worksheet for the worst FTE reporters\n",
    "suspects = [\"312018\", \"360044\", \"220071\", \"244002\", \"431301\"]\n",
    "\n",
    "nmrc_full = pd.read_parquet(\n",
    "    BASE_DIR / \"HOSP10FY2015\" / \"hosp10_2015_NMRC.parquet\"\n",
    ")\n",
    "\n",
    "for prvdr in suspects:\n",
    "    # Find their RPT_REC_NUM for that year\n",
    "    rpt_num = master_panel[\n",
    "        (master_panel[\"PRVDR_NUM\"] == prvdr) & \n",
    "        (master_panel[\"source_year\"] == 2015)\n",
    "    ][\"RPT_REC_NUM\"].values\n",
    "    \n",
    "    if len(rpt_num) == 0:\n",
    "        continue\n",
    "        \n",
    "    print(f\"\\n=== {prvdr} S3 WORKSHEET ===\")\n",
    "    s3 = nmrc_full[\n",
    "        (nmrc_full[\"WKSHT_CD\"].str.startswith(\"S3\")) &\n",
    "        (nmrc_full[\"RPT_REC_NUM\"] == rpt_num[0])\n",
    "    ][[\"WKSHT_CD\",\"LINE_NUM\",\"CLMN_NUM\",\"ITM_VAL_NUM\"]].sort_values(\n",
    "        [\"WKSHT_CD\",\"LINE_NUM\",\"CLMN_NUM\"]\n",
    "    )\n",
    "    print(s3.to_string())"
   ]
  },
