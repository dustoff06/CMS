    "import pandas as pd\n",
    "from pathlib import Path\n",
    "\n",
    "BASE_DIR   = Path(r\"/mnt/c/Users/lfult/OneDrive - bc.edu/Desktop/CMS Cost Reports\")\n",
    "FY         = \"2015\"\n",
    "ALPHA_PATH = BASE_DIR / f\"HOSP10FY{FY}\" / f\"hosp10_{FY}_ALPHA.parquet\"\n",
    "RPT_PATH   = BASE_DIR / f\"HOSP10FY{FY}\" / f\"hosp10_{FY}_RPT.parquet\"\n",
    "\n",
    "alpha = pd.read_parquet(ALPHA_PATH)\n",
    "alpha.columns = [\"RPT_REC_NUM\",\"WKSHT_CD\",\"LINE_NUM\",\"CLMN_NUM\",\"ITM_VAL_TXT\"]\n",
    "\n",
    "rpt = pd.read_parquet(RPT_PATH)\n",
    "rpt.columns = range(len(rpt.columns))  # reset to positional\n",
    "\n",
    "# Prepend the lost first row back\n",
    "first_row = pd.DataFrame([[556684, 4, 454129, None, 2, '10/28/2014', '12/31/2014',\n",
    "                            '06/24/2015', 'N', 'N', 'F', '04011', 4, '06/23/2015',\n",
    "                            'L', '07/09/2015', None, '06/05/2015']], columns=range(18))\n",
    "rpt = pd.concat([first_row, rpt], ignore_index=True)\n",
    "\n",
    "# Now assign proper names\n",
    "rpt.columns = RPT_COLS\n",
    "rpt.columns = rpt.columns.str.strip()\n",
    "\n",
    "# --- Find a confirmed CAH: PRVDR_NUM ending in 13xx ---\n",
    "cah_rpt = rpt[rpt[\"PRVDR_NUM\"].str[2:4] == \"13\"].head(1)\n",
    "\n",
    "# --- Find a fiscal year change hospital: FY_BGN_DT month != 10 (non-Oct start) ---\n",
    "# and compare consecutive years to find one that actually changed\n",
    "rpt[\"FY_BGN_DT\"] = pd.to_datetime(rpt[\"FY_BGN_DT\"], errors=\"coerce\")rpt[\"FY_BGN_DT\"] = pd.to_datetime(rpt[\"FY_BGN_DT\"], errors=\"coerce\")\n",
    "nmrc[\"FY_BGN_DT\"] = pd.to_datetime(\n",
    "    rpt.set_index(\"RPT_REC_NUM\")[\"FY_BGN_DT\"],  # join key to propagate dates\n",
    "    errors=\"coerce\"\n",
    ")\n",
    "fy_chg_rpt = rpt[rpt[\"FY_BGN_DT\"].dt.month != 10].head(1)\n",
    "\n",
    "test_cases = pd.concat([cah_rpt, fy_chg_rpt])[[\"RPT_REC_NUM\",\"PRVDR_NUM\",\"FY_BGN_DT\",\"FY_END_DT\"]]\n",
    "print(\"Test providers selected:\")\n",
    "print(test_cases.to_string(index=False))\n",
    "\n",
    "# --- Run the spot-check ---\n",
    "alpha_sub = alpha[alpha[\"RPT_REC_NUM\"].isin(test_cases[\"RPT_REC_NUM\"])]\n",
    "alpha_sub = alpha_sub.merge(test_cases, on=\"RPT_REC_NUM\")\n",
    "\n",
    "suspect = [\n",
    "    (\"urban_rural_status\",     \"S200001\", \"00300\", \"00600\"),\n",
    "    (\"fiscal_year_end_change\", \"S200001\", \"01300\", \"00100\"),\n",
    "]\n",
    "\n",
    "for name, ws, line, col in suspect:\n",
    "    hits = alpha_sub[\n",
    "        (alpha_sub[\"WKSHT_CD\"] == ws) &\n",
    "        (alpha_sub[\"LINE_NUM\"]  == line) &\n",
    "        (alpha_sub[\"CLMN_NUM\"]  == col)\n",
    "    ][[\"PRVDR_NUM\",\"FY_BGN_DT\",\"ITM_VAL_TXT\"]]\n",
    "    print(f\"\\n{name}  ({ws} / {line} / {col})\")\n",
    "    print(hits.to_string(index=False) if not hits.empty else \"  *** NO DATA ***\")"
   ]
