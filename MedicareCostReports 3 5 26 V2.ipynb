    "import pandas as pd\n",
    "\n",
    "nmrc = pd.read_csv(\n",
    "    r\"/mnt/c/Users/lfult/OneDrive - bc.edu/Desktop/CMS Cost Reports/HOSP10FY2011/HOSP10_2011_nmrc.csv\",\n",
    "    header=None,\n",
    "    names=[\"RPT_REC_NUM\",\"WKSHT_CD\",\"LINE_NUM\",\"CLMN_NUM\",\"ITM_VAL_NUM\"],\n",
    "    dtype=str\n",
    ")\n",
    "\n",
    "nmrc[\"WKSHT_CD\"] = nmrc[\"WKSHT_CD\"].str.strip()\n",
    "\n",
    "\n",
    "import pandas as pd\n",
    "\n",
    "def debug_s3_line(nmrc: pd.DataFrame, ws: str, line: str, top_cols: int = 20, sample_n: int = 10):\n",
    "    \"\"\"\n",
    "    Debug a single S-3 line by showing:\n",
    "      1) which CLMN_NUM values exist for that LINE_NUM\n",
    "      2) summary stats for each CLMN_NUM (so you can spot the 'real' count column)\n",
    "      3) a few sample rows for the most common columns\n",
    "    Assumes nmrc has columns: RPT_REC_NUM, WKSHT_CD, LINE_NUM, CLMN_NUM, ITM_VAL_NUM\n",
    "    \"\"\"\n",
    "    df = nmrc.copy()\n",
    "\n",
    "    # Normalize like your pipeline does\n",
    "    df[\"WKSHT_CD\"] = df[\"WKSHT_CD\"].astype(str).str.strip()\n",
    "    df[\"LINE_NUM\"] = df[\"LINE_NUM\"].astype(str).str.strip().str.replace(r\"\\.0$\", \"\", regex=True).str.zfill(5)\n",
    "    df[\"CLMN_NUM\"] = df[\"CLMN_NUM\"].astype(str).str.strip().str.replace(r\"\\.0$\", \"\", regex=True).str.zfill(5)\n",
    "\n",
    "    ws = ws.strip()\n",
    "    line = str(line).strip().zfill(5)\n",
    "\n",
    "    sub = df[(df[\"WKSHT_CD\"] == ws) & (df[\"LINE_NUM\"] == line)].copy()\n",
    "    print(f\"\\n=== DEBUG {ws} LINE {line} ===\")\n",
    "    print(\"Rows:\", len(sub))\n",
    "\n",
    "    if sub.empty:\n",
    "        print(\"No rows found for this worksheet/line.\")\n",
    "        return\n",
    "\n",
    "    # Column presence\n",
    "    col_counts = sub[\"CLMN_NUM\"].value_counts().head(top_cols)\n",
    "    print(\"\\nTop CLMN_NUM values by count:\")\n",
    "    print(col_counts)\n",
    "\n",
    "    # Numeric summaries by column\n",
    "    sub[\"ITM_VAL_NUM\"] = pd.to_numeric(sub[\"ITM_VAL_NUM\"], errors=\"coerce\")\n",
    "    summaries = (\n",
    "        sub.groupby(\"CLMN_NUM\")[\"ITM_VAL_NUM\"]\n",
    "           .agg([\"count\", \"mean\", \"std\", \"min\", \"median\", \"max\"])\n",
    "           .sort_values([\"count\",\"max\"], ascending=False)\n",
    "    )\n",
    "    print(\"\\nSummary stats by CLMN_NUM (sorted by count, then max):\")\n",
    "    print(summaries.head(top_cols))\n",
    "\n",
    "    # Sample values for the most common columns\n",
    "    print(\"\\nSample rows for most common CLMN_NUM values:\")\n",
    "    for c in col_counts.index[:min(5, len(col_counts))]:\n",
    "        samp = sub[sub[\"CLMN_NUM\"] == c][[\"RPT_REC_NUM\",\"WKSHT_CD\",\"LINE_NUM\",\"CLMN_NUM\",\"ITM_VAL_NUM\"]].head(sample_n)\n",
    "        print(f\"\\n--- CLMN_NUM {c} sample ---\")\n",
    "        print(samp.to_string(index=False))\n",
    "\n",
    "\n",
    "def check_mapping_exists(nmrc: pd.DataFrame, ws: str, line: str, col: str, show: int = 20):\n",
    "    \"\"\"\n",
    "    Quick yes/no check for a specific mapping (ws,line,col) plus a peek at values.\n",
    "    \"\"\"\n",
    "    df = nmrc.copy()\n",
    "    df[\"WKSHT_CD\"] = df[\"WKSHT_CD\"].astype(str).str.strip()\n",
    "    df[\"LINE_NUM\"] = df[\"LINE_NUM\"].astype(str).str.strip().str.replace(r\"\\.0$\", \"\", regex=True).str.zfill(5)\n",
    "    df[\"CLMN_NUM\"] = df[\"CLMN_NUM\"].astype(str).str.strip().str.replace(r\"\\.0$\", \"\", regex=True).str.zfill(5)\n",
    "\n",
    "    ws = ws.strip()\n",
    "    line = str(line).strip().zfill(5)\n",
    "    col  = str(col).strip().zfill(5)\n",
    "\n",
    "    sub = df[(df[\"WKSHT_CD\"] == ws) & (df[\"LINE_NUM\"] == line) & (df[\"CLMN_NUM\"] == col)].copy()\n",
    "    print(f\"\\n=== CHECK {ws} {line} {col} ===\")\n",
    "    print(\"Rows:\", len(sub))\n",
    "    if sub.empty:\n",
    "        print(\"No rows. This coordinate does not exist in this year/file.\")\n",
    "        return\n",
    "    sub[\"ITM_VAL_NUM\"] = pd.to_numeric(sub[\"ITM_VAL_NUM\"], errors=\"coerce\")\n",
    "    print(sub[[\"RPT_REC_NUM\",\"ITM_VAL_NUM\"]].head(show).to_string(index=False))\n",
    "    print(\"\\nDescribe:\")\n",
    "    print(sub[\"ITM_VAL_NUM\"].describe())\n",
    "\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# RUN THESE TWO LINES FOR YOUR TWO FEATURES (2011 NMRC)\n",
    "# ------------------------------------------------------------\n",
    "\n",
    "# 1) total_discharges candidate mapping\n",
    "debug_s3_line(nmrc, ws=\"S300001\", line=\"01400\")\n",
    "check_mapping_exists(nmrc, ws=\"S300001\", line=\"01400\", col=\"01500\")  # your current guess\n",
    "\n",
    "# 2) outpatient_visits candidate mapping\n",
    "debug_s3_line(nmrc, ws=\"S300001\", line=\"00100\")\n",
    "check_mapping_exists(nmrc, ws=\"S300001\", line=\"00100\", col=\"01500\")  # your current guess\n",
    "\n",
    "debug_s3_line(nmrc, ws=\"S300001\", line=\"00100\")\n",
    "check_mapping_exists(nmrc, ws=\"S300001\", line=\"00100\", col=\"01500\")"
   ]
  },
